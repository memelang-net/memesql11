""" Schema """
%mode=tab;employees id :DESC="Employee ID";:int>0;first_name :DESC="Given name";:str;last_name :DESC="Family name";:str;email :DESC="Work email (unique)";:str;phone :DESC="Phone number";:str;hire_date :DESC="Hire date";:date;department_id :DESC="key to departments.id";:int;job_id :DESC="key to jobs.id";:int;manager_id :DESC="key to employees.id (manager)";:int;status :DESC="Employment status";:str;=active,on_leave,terminated;salary :DESC="Base salary";:dec>=0.0;bonus_target :DESC="Bonus target amount";:dec>=0.0;full_time :DESC="Full-time flag";:bool;created :DESC="Creation timestamp";:date;;departments id :DESC="Department ID";:int>0;name :DESC="Department name";:str;location_id :DESC="key to locations.id";:int;created :DESC="Creation timestamp";:date;;jobs id :DESC="Job ID";:int>0;title :DESC="Job title";:str;grade :DESC="Job grade/band";:str;min_salary :DESC="Minimum salary for band";:dec>=0.0;max_salary :DESC="Maximum salary for band";:dec>=0.0;exempt :DESC="FLSA exempt";:bool;created :DESC="Creation timestamp";:date;;locations id :DESC="Location ID";:int>0;name :DESC="Location/site name";:str;country :DESC="Country";:str;region :DESC="State/Region";:str;timezone :DESC="IANA timezone";:str;created :DESC="Creation timestamp";:date;;benefit_plans id :DESC="Benefit plan ID";:int>0;name :DESC="Plan name";:str;type :DESC="Plan type";:str;=medical,dental,vision,retirement,life;active :DESC="Plan active flag";:bool;created :DESC="Creation timestamp";:date;;employee_benefits id :DESC="Employee benefit row ID";:int>0;employee_id :DESC="key to employees.id";:int;benefit_plan_id :DESC="key to benefit_plans.id";:int;start_date :DESC="Coverage start";:date;end_date :DESC="Coverage end";:date;coverage_level :DESC="Coverage level";:str;=employee,employee_spouse,employee_children,family;created :DESC="Creation timestamp";:date;;performance_reviews id :DESC="Performance review ID";:int>0;employee_id :DESC="key to employees.id";:int;reviewer_id :DESC="key to employees.id (reviewer)";:int;review_date :DESC="Review date";:date;period_start :DESC="Period start";:date;period_end :DESC="Period end";:date;rating :DESC="Overall rating 0-5";:dec>=0.0;<=5;comments :DESC="Freeform notes";:str;created :DESC="Creation timestamp";:date;;time_off_requests id :DESC="Time-off request ID";:int>0;employee_id :DESC="key to employees.id";:int;request_date :DESC="Request submitted";:date;start_date :DESC="Start date";:date;end_date :DESC="End date";:date;type :DESC="Time-off type";:str;=vacation,sick,personal,unpaid,bereavement,parental;status :DESC="Approval status";:str;=pending,approved,denied,canceled;hours :DESC="Requested hours";:dec>=0.0;created :DESC="Creation timestamp";:date;;timesheets id :DESC="Timesheet ID";:int>0;employee_id :DESC="key to employees.id";:int;week_start :DESC="Week start date";:date;hours_worked :DESC="Regular hours";:dec>=0.0;overtime_hours :DESC="OT hours";:dec>=0.0;submitted :DESC="Submitted flag";:bool;approved :DESC="Approved flag";:bool;approver_id :DESC="key to employees.id (approver)";:int;created :DESC="Creation timestamp";:date;;skills id :DESC="Skill ID";:int>0;name :DESC="Skill name";:str;category :DESC="Skill category";:str;created :DESC="Creation timestamp";:date;;employee_skills id :DESC="Employee/skill link ID";:int>0;employee_id :DESC="key to employees.id";:int;skill_id :DESC="key to skills.id";:int;level :DESC="Proficiency";:str;=beginner,intermediate,advanced,expert;last_used :DESC="Last used date";:date;created :DESC="Creation timestamp";:date;;payroll_runs id :DESC="Payroll run ID";:int>0;pay_period_start :DESC="Period start";:date;pay_period_end :DESC="Period end";:date;pay_date :DESC="Pay date";:date;status :DESC="Run status";:str;=draft,processed,paid,void;notes :DESC="Notes";:str;created :DESC="Creation timestamp";:date;;payroll_entries id :DESC="Payroll entry ID";:int>0;payroll_run_id :DESC="key to payroll_runs.id";:int;employee_id :DESC="key to employees.id";:int;gross_pay :DESC="Gross pay";:dec>=0.0;tax_withheld :DESC="Tax withheld";:dec>=0.0;net_pay :DESC="Net pay";:dec>=0.0;currency :DESC="Currency code";:str;created :DESC="Creation timestamp";:date;;departments id _;employees department_id @;;jobs id _;employees job_id @;;locations id _;departments location_id @;;benefit_plans id _;employee_benefits benefit_plan_id @;;skills id _;employee_skills skill_id @;;payroll_runs id _;payroll_entries payroll_run_id @;;employees id _;employees manager_id @;employee_benefits employee_id @;performance_reviews employee_id @;performance_reviews reviewer_id @;time_off_requests employee_id @;timesheets employee_id @;timesheets approver_id @;employee_skills employee_id @;payroll_entries employee_id @;;employees id :pri;;departments id :pri;;jobs id :pri;;locations id :pri;;benefit_plans id :pri;;employee_benefits id :pri;;performance_reviews id :pri;;time_off_requests id :pri;;timesheets id :pri;;skills id :pri;;employee_skills id :pri;;payroll_runs id :pri;;payroll_entries id :pri;;employees email :grp:cnt=1;;skills name :grp:cnt=1;;benefit_plans name :grp:cnt=1;;locations name :grp:cnt=1;;departments location_id :grp;name :grp:cnt=1;;jobs title :grp;grade :grp:cnt=1;;employee_benefits employee_id :grp;benefit_plan_id :grp;start_date :grp:cnt=1;;employee_skills employee_id :grp;skill_id :grp:cnt=1;;timesheets employee_id :grp;week_start :grp:cnt=1;;payroll_entries payroll_run_id :grp;employee_id :grp:cnt=1;;performance_reviews employee_id :grp;period_start :grp;period_end :grp:cnt=1;;time_off_requests employee_id :grp;start_date :grp;end_date :grp:cnt=1;;payroll_runs pay_period_start :grp;pay_period_end :grp:cnt=1;;
