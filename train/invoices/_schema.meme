""" Schema """
% mode tab;customers id :int;:DESC="Customer ID number";name :str;:DESC="Customer full name";email :str;:DESC="Customer email address";phone :str;:DESC="Phone number as text";created :date;:DESC="Creation timestamp";;products id :int;:DESC="Product ID number";sku :str;:DESC="Stock keeping unit";name :str;:DESC="Product display name";unit_price :dec>=0.0;:DESC="Unit price, non-negative";active :bool;:DESC="Whether product is active";created :date;:DESC="Creation timestamp";;invoices id :int;:DESC="Invoice ID number";customer_id :int;:DESC="Reference to customers ID number";invoice_no :str;:DESC="External invoice number";invoice_date :date;:DESC="Invoice issue date";due_date :date;:DESC="Payment due date";status :str;=open,paid,overdue;:DESC="Invoice status";subtotal :dec>=0.0;:DESC="Sum of line items before tax";tax :dec>=0.0;:DESC="Tax amount";total :dec>=0.0;:DESC="Grand total";created :date;:DESC="Creation timestamp";;invoice_items id :int;:DESC="Invoice item ID number";invoice_id :int;:DESC="Reference to invoices ID number";product_id :int;:DESC="Reference to products ID number";description :str;:DESC="Line item description";quantity :int>0;:DESC="Quantity of product";unit_price :dec>=0.0;:DESC="Unit price at time of sale";line_total :dec>=0.0;:DESC="Quantity times unit price";;customers id _;invoices customer_id @;;products id _;invoice_items product_id @;;invoices id _;invoice_items invoice_id @;;products sku :pri;;customers id :pri;;products id :pri;;invoices id :pri;;invoice_items id :pri;;